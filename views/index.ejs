<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>EventosPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/48/confetti.png">
    <style>
        .card-hover:hover {
            transform: translateY(-8px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    

    <nav class="flex justify-between items-center p-6 bg-white shadow-sm animate__animated animate__fadeInDown">
        <div class="text-2xl font-bold font-display flex items-center gap-2">
            <span class="material-icons text-orange-600">event</span> EventosPro
        </div>
        <div class="flex gap-4 items-center">
            <button id="btnEventos" class="hover:bg-gray-100 px-4 py-2 rounded-md transition duration-200">Eventos</button>
            <button id="btn-entrar-nav" onclick="window.location='/login'" class="bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700 active:scale-95 transition-all">Entrar</button>
        </div>

        <div id="menu-usuario-nav" class="hidden flex items-center gap-4">
            <a href="#" id="link-dashboard" class="bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-orange-700 shadow-lg shadow-orange-200 transition-all active:scale-95">Dashboard</a>
            <div class="flex items-center gap-3 bg-orange-600 border border-gray-100 px-5 py-2.5 rounded-xl cursor-pointer hover:bg-orange-700 transition-all shadow-sm" onclick="window.location='/dashboard-organizador'">
                <div class="text-lg w-8 h-8 flex items-center justify-center rounded-lg">👤</div>
                <span id="nome-mini-nav" class="text-white font-bold text-lg ">Usuário</span>
            </div>
            <button onclick="logout()" class="bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-orange-700 shadow-lg shadow-orange-200 transition-all active:scale-95">Sair</button>
        </div>
    </nav>

    <header class="text-center py-16 animate__animated animate__fadeIn">
        <h1 class="text-5xl font-extrabold text-gray-900">Descubra Eventos <span class="text-orange-600">Incríveis</span></h1>
        <p class="text-gray-500 mt-4 text-lg">Encontre e participe dos melhores eventos perto de você</p>
        
        <div class="max-w-4xl mx-auto mt-10 relative px-4">
            <input type="text" placeholder="Buscar eventos, locais, tags..." 
                   class="w-full p-4 pl-12 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 outline-none transition-all shadow-sm">
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pb-20">
        <p class="text-gray-500 mb-6 font-medium"><%= eventos.length %> evento(s) encontrado(s)</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% eventos.forEach((evento, index) => { %>
                <div onclick="window.location='/evento/<%= evento.id %>'" class="group cursor-pointer bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 card-hover animate__animated animate__fadeInUp" 
                     style="animation-delay: <%= index * 0.1 %>s">
                    
                    <div class="relative h-56 overflow-hidden bg-gray-200">
                        <div class="w-full h-full bg-cover bg-center transition-transform duration-700 ease-in-out group-hover:scale-110 group-hover:text-orange-600 " 
                             style="background-image: url('<%= evento.img %>');">
                    </div>

                        <div class="absolute top-4 left-4 flex gap-2">
                            <span class="bg-orange-600 text-white text-xs px-3 py-1 rounded-full font-bold uppercase"><%= evento.categoria %></span>
                            <% if(evento.gratis) { %>
                                <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full font-bold uppercase">Gratuito</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2 transition-colors duration-300 group-hover:text-orange-600"><%= evento.titulo %></h3>
                        <div class="text-gray-500 text-sm space-y-1 mb-4">
                            <p>📅 <%= evento.data %> • 🕒 18:00</p>
                            <p>📍 <%= evento.local %></p>
                            <p>👥 <%= evento.vagas %></p>
                        </div>
                        <div class="text-2xl font-bold text-orange-600">
                            R$ <%= evento.preco %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </main>

    <script>
    function verificarStatusLogin() {
        const usuario = localStorage.getItem('usuario_teste');
        const perfil = localStorage.getItem('perfil_escolhido');

        const btnEntrar = document.getElementById('btn-entrar-nav'); 
        const menuUsuario = document.getElementById('menu-usuario-nav'); 
        const linkDash = document.getElementById('link-dashboard');
        const btnEvento = document.getElementById('btnEventos');

        if (usuario && perfil) {
            
            
            if(btnEntrar) btnEntrar.classList.add('hidden');
            if(btnEventos) btnEvento.classList.add('hidden');
            if(menuUsuario) menuUsuario.classList.remove('hidden');
            
            
            const dados = JSON.parse(usuario);
            const nomeMini = document.getElementById('nome-mini-nav');
            if(nomeMini) nomeMini.innerText = dados.nome.split(' ')[0];

            if(linkDash) {
                if(perfil === 'organizador') {
                    linkDash.href = '/dashboard-organizador';
                } else {
                    linkDash.href = '/dashboard-participante';
                }
            }
        } else {
            
            
            if(btnEntrar) btnEntrar.classList.remove('hidden');
            if(btnEvento) btnEvento.classList.remove('hidden');
            if(menuUsuario) menuUsuario.classList.add('hidden');
        }
    }

    function logout() {
        localStorage.removeItem('perfil_escolhido');
    
        window.location.href = '/';
    }

    
    window.onload = verificarStatusLogin;
</script>
</body>
</html>