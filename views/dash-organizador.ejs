<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | EventosPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-gray-50 font-sans min-h-screen">

    <nav class="flex justify-between items-center px-8 py-4 bg-white shadow-sm border-b border-gray-100 sticky top-0 z-50">
        <div class="text-2xl font-bold flex items-center gap-2 cursor-pointer" onclick="window.location='/'">
            <span class="p-1.5 bg-orange-600 rounded-xl text-white text-sm">📅</span> 
            <span class="tracking-tight text-gray-900">EventosPro</span>
        </div>

        <div class="flex items-center gap-6">
            <div class="hidden md:flex items-center gap-6 text-sm font-bold text-gray-500 mr-4">
                <a href="/" class="bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-orange-700 shadow-lg shadow-orange-200 transition-all active:scale-95">
                    <span>🏠</span> Eventos
                </a>
                <a href="/dashboard-organizador" class="bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-orange-700 shadow-lg shadow-orange-200 transition-all active:scale-95">
                    <span>📊</span> Dashboard
                </a>
            </div>

            <button onclick="abrirModalCriarEvento()" class="bg-orange-600 text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-orange-700 shadow-lg shadow-orange-200 transition-all active:scale-95">
                <span class="text-xl leading-none">+</span> Criar Evento
            </button>

            <div class="flex items-center gap-3 bg-gray-50 px-4 py-2 rounded-2xl border border-gray-100">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center text-sm">👤</div>
                <span id="nameOrganizador" class="font-bold text-gray-700 text-sm"></span>
            </div>

            <button onclick="logout()" class="flex items-center gap-2 text-gray-400 font-bold hover:text-red-500 transition-colors text-sm">
                <span>🚪</span> Sair
            </button>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-8 py-10 animate__animated animate__fadeIn">
        <header class="mb-10">
            <h1 class="text-4xl font-black text-gray-900 tracking-tight">Dashboard</h1>
            <p class="text-gray-500 font-medium">Visão geral dos seus eventos</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                <div class="bg-orange-50 p-4 rounded-2xl text-2xl">📅</div>
                <div>
                    <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Total de Eventos</p>
                    <p class="text-3xl font-black text-gray-900 leading-none mt-1">6</p>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                <div class="bg-purple-50 p-4 rounded-2xl text-2xl">👥</div>
                <div>
                    <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Inscrições</p>
                    <p class="text-3xl font-black text-gray-900 leading-none mt-1">4</p>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                <div class="bg-green-50 p-4 rounded-2xl text-2xl">📈</div>
                <div>
                    <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Capacidade Total</p>
                    <p class="text-3xl font-black text-gray-900 leading-none mt-1">2130</p>
                </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-100 flex items-center gap-5 hover:shadow-md transition-shadow">
                <div class="bg-yellow-50 p-4 rounded-2xl text-2xl">💰</div>
                <div>
                    <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest">Receita Estimada</p>
                    <p class="text-3xl font-black text-gray-900 leading-none mt-1">R$ 112.991</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100">
                <h3 class="text-xl font-bold mb-8 text-gray-900">Inscrições por Evento</h3>
                <canvas id="barChart" height="200"></canvas>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100">
                <h3 class="text-xl font-bold mb-8 text-gray-900">Eventos por Categoria</h3>
                <div class="max-w-[280px] mx-auto">
                    <canvas id="doughnutChart"></canvas>
                </div>
            </div>
        </div>
    </main>

    <script>

        const user = JSON.parse(localStorage.getItem('usuario_teste'))

        const perfil = localStorage.getItem('perfil_escolhido');

        if(user) {
            document.getElementById('nameOrganizador').innerText = user.nome;
        }

        if (!user || perfil !== 'organizador') {
        
            window.location.href = '/login'; 
        }
        // Função do Modal de Criação
        function abrirModalCriarEvento() {
            Swal.fire({
                title: 'Criar Novo Evento',
                html: `
                    <div class="text-left space-y-4 p-2">
                        <input id="swal-titulo" class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all" placeholder="Título do Evento">
                        <div class="grid grid-cols-2 gap-4">
                            <input id="swal-data" type="date" class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all">
                            <input id="swal-preco" type="number" class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all" placeholder="Preço (R$)">
                        </div>
                        <input id="swal-local" class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all" placeholder="Localização">
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Confirmar e Publicar',
                confirmButtonColor: '#ea580c',
                cancelButtonText: 'Cancelar',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-[2.5rem]',
                    title: 'font-black text-2xl pt-6',
                    confirmButton: 'px-8 py-3 rounded-xl font-bold',
                    cancelButton: 'px-8 py-3 rounded-xl font-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Evento Criado!',
                        icon: 'success',
                        confirmButtonColor: '#ea580c',
                        customClass: { popup: 'rounded-[2.5rem]' }
                    });
                }
            });
        }

        // Função Logout
        function logout() {
            localStorage.removeItem('perfil_escolhido');
            window.location.href = '/login';
        }

        // --- Gráficos ---
        const barCtx = document.getElementById('barChart').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: ['Workshop de Des...', 'Feira Gastronôm...', 'Maratona de Programação...'],
                datasets: [{
                    label: 'Inscrições',
                    data: [350, 720, 210],
                    backgroundColor: '#ea580c',
                    borderRadius: 12,
                    barThickness: 40
                }, {
                    label: 'Capacidade',
                    data: [500, 1000, 300],
                    backgroundColor: '#e5e7eb',
                    borderRadius: 12,
                    barThickness: 40
                }]
            },
            options: { 
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } }
            }
        });

        const doughCtx = document.getElementById('doughnutChart').getContext('2d');
        new Chart(doughCtx, {
            type: 'doughnut',
            data: {
                labels: ['Tecnologia', 'Música', 'Negócios', 'Esportes', 'Gastronomia', 'Workshop'],
                datasets: [{
                    data: [15, 20, 15, 10, 20, 20],
                    backgroundColor: ['#7c3aed', '#ea580c', '#db2777', '#0ea5e9', '#f59e0b', '#10b981'],
                    borderWidth: 0,
                    weight: 0.5
                }]
            },
            options: {
                plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { weight: 'bold' } } } },
                cutout: '75%'
            }
        });
    </script>
</body>
</html>