<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Conta | EventosPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/48/user-male-circle.png">
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col">

    <nav class="flex justify-between items-center p-6 bg-white shadow-sm">
        <div class="text-2xl font-bold flex items-center gap-2 cursor-pointer" onclick="window.location='/'">
            <span class="p-1 bg-orange-600 rounded-lg text-white text-sm">📅</span> EventosPro
        </div>
    </nav>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-xl border border-gray-100 animate__animated animate__fadeInUp">
            
            <div class="flex justify-center mb-6">
                <div class="bg-orange-50 p-4 rounded-2xl">
                    <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                </div>
            </div>

            <h1 class="text-3xl font-black text-center text-gray-900 mb-2">Criar Conta</h1>
            <p class="text-center text-gray-500 mb-10">Junte-se a nós para descobrir eventos</p>

            <form action="/registro" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Nome Completo</label>
                    <input type="text" placeholder="Seu nome" required
                           class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">E-mail</label>
                    <input type="email" placeholder="seu@email.com" required
                           class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Senha</label>
                    <input type="password" placeholder="Mínimo 6 caracteres" required
                           class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all">
                </div>

                <button type="submit" class="w-full bg-orange-600 text-white font-bold py-4 rounded-2xl hover:bg-orange-700 active:scale-[0.98] transition-all shadow-lg shadow-orange-100 mt-4">
                    Registrar agora
                </button>
            </form>

            <p class="text-center mt-8 text-gray-500">
                Já tem uma conta? <a href="/login" class="text-orange-600 font-bold hover:underline">Faça login</a>
            </p>
        </div>
    </main>

    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            e.preventDefault();
        
            const novoUsuario = {
                nome: document.querySelector('input[placeholder="Seu nome"]').value,
                email: document.querySelector('input[placeholder="seu@email.com"]').value,
                senha: document.querySelector('input[type="password"]').value
            };

        
            localStorage.setItem('usuario_teste', JSON.stringify(novoUsuario));

            Swal.fire('Conta criada!', 'Dados salvos no seu navegador.', 'success')
                .then(() => window.location.href = '/login');
        });
    </script>

</body>
</html>