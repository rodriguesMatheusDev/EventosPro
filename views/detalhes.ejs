<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= evento.titulo %> | EventosPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/48/ticket.png">
</head>
<body class="bg-gray-50 font-sans">

    <nav class="flex justify-between items-center p-6 bg-white shadow-sm">
        <div class="text-2xl font-bold flex items-center gap-2 cursor-pointer" onclick="window.location='/'">
            <span class="p-2 rounded-lg">📅</span> EventosPro
        </div>
        <div class="flex gap-4 items-center">
            <button id="btnLogar0" onclick="window.location='/login'" class="bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700 active:scale-95 transition-all">Entrar</button>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-10">
        <button onclick="window.history.back()" class="flex items-center gap-2 text-gray-600 hover:text-orange-600 transition-colors mb-8 group">
            <span class="group-hover:-translate-x-1 transition-transform">←</span> Voltar
        </button>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            <div class="lg:col-span-2 animate__animated animate__fadeInLeft">
                <div class="rounded-3xl overflow-hidden shadow-lg mb-8">
                    <img src="<%= evento.img %>" alt="<%= evento.titulo %>" class="w-full h-[450px] object-cover">
                </div>

                <h1 class="text-4xl font-extrabold text-gray-900 mb-2"><%= evento.titulo %></h1>
                <p class="text-gray-500 mb-6 font-medium">Organizado por <span class="text-orange-600">Eventos SP</span></p>

                <div class="flex flex-wrap gap-6 text-gray-600 mb-10 pb-10 border-b border-gray-200">
                    <div class="flex items-center gap-2">📅 <span>Terça-feira, <%= evento.data %></span></div>
                    <div class="flex items-center gap-2">🕒 <span>18:00</span></div>
                    <div class="flex items-center gap-2">📍 <span><%= evento.local %>, São Paulo</span></div>
                    <div class="flex items-center gap-2">👥 <span><%= evento.vagas %> inscritos</span></div>
                </div>

                <section class="mb-10">
                    <h2 class="text-2xl font-bold mb-4">Sobre o Evento</h2>
                    <p class="text-gray-600 leading-relaxed mb-6">
                        <%= evento.descricao %>
                    </p>
    
                    <div class="flex gap-3">
                        <% if(evento.tags && evento.tags.length > 0) { %>
                            <% evento.tags.forEach(tag => { %>
                    <span class="bg-gray-100 px-4 py-1.5 rounded-full text-sm font-medium text-gray-600">
                        #<%= tag %>
                    </span>
                            <% }); %>
                        <% } %>
                    </div>
                </section>

                <section class="mt-10 animate__animated animate__fadeInUp">
                    <h2 class="text-2xl font-bold mb-6">Localização</h2>
    
                    <div id="map" class="w-full h-[300px] rounded-3xl overflow-hidden shadow-inner border border-gray-100"></div>
    
                        <p class="text-gray-500 mt-4 flex items-center gap-2 italic text-sm">
                            📍 <%= evento.local %>, São Paulo - SP
                        </p>
                </section>

            </div>

            <div class="lg:col-span-1">
                <div class="sticky top-10 bg-white p-8 rounded-[2rem] shadow-xl border border-gray-100 animate__animated animate__fadeInRight">
                    <div class="text-3xl font-black text-orange-600 mb-6">R$ <%= evento.preco %></div>
                    
                    <div class="flex justify-between text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide">
                        <span>342 inscritos</span>
                        <span>158 vagas restantes</span>
                    </div>
                    <div class="w-full h-3 bg-gray-100 rounded-full mb-8 overflow-hidden">
                        <div class="h-full bg-orange-600 rounded-full transition-all duration-1000" style="width: 68%"></div>
                    </div>

                    <h3 class="font-bold text-lg mb-4">Inscreva-se</h3>
                    <form class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">Nome completo</label>
                            <input type="text" placeholder="Seu nome" class="w-full p-4 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 transition-all outline-none text-gray-600">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">E-mail</label>
                            <input type="email" placeholder="seu@email.com" class="w-full p-4 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 transition-all outline-none text-gray-600">
                        </div>
                        <form id="formInscricao" class="space-y-4">
                            <button type="button" onclick="inscreverNoEvento(event);" id="btnConfirmar" class="w-full bg-orange-600 text-white font-bold py-4 rounded-2xl hover:bg-orange-700 active:scale-[0.98] transition-all shadow-lg shadow-orange-100 mt-4">
                                Confirmar Inscrição
                            </button>
                        </form>
                        <button type="button" class="w-full flex items-center justify-center gap-2 text-gray-500 font-bold py-4 hover:text-gray-700 transition-colors">
                            <span>🔗</span> Compartilhar
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </main>

    <script>



        const usuario = localStorage.getItem('usuario_teste');
        const perfil = localStorage.getItem('perfil_escolhido');
        const btnLogar = document.getElementById('btnLogar0'); 

        if (usuario && perfil) {
            if(btnLogar) btnLogar.classList.add('hidden');

        } else {

            if (btnLogar) btnLogar.classList.remove('hidden');

        }


        function inscreverNoEvento(event) {

            if (event) event.preventDefault();


            const usuarioLogado = localStorage.getItem('usuario_teste');
            const perfilAtivo = localStorage.getItem('perfil_escolhido');

            if (!usuarioLogado || !perfilAtivo) {
                Swal.fire({
                    title: 'Ops!',
                    text: 'Você precisa estar logado como Participante para se inscrever.',
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: 'Fazer Login',
                    confirmButtonColor: '#ea580c',
                    cancelButtonText: 'Cancelar',
                    customClass: { popup: 'rounded-[2rem]' }
            }).then((result) => {
                if (result.isConfirmed) window.location.href = '/login';
            });
            return;
        }

        if (perfilAtivo === 'organizador') {
            Swal.fire({
                title: 'Atenção',
                text: 'Apenas contas de Participante podem se inscrever em eventos.',
                icon: 'warning',
                confirmButtonColor: '#ea580c',
                customClass: { popup: 'rounded-[2rem]' }
            });
            return;
        }

        Swal.fire({
            title: 'Inscrição Confirmada!',
            text: 'Sua vaga foi reservada com sucesso.',
            icon: 'success',
            confirmButtonColor: '#ea580c',
            customClass: { popup: 'rounded-[2rem]' }
        });
    }

    

    
    
    
    var map = L.map('map').setView([-23.5874, -46.6576], 13); 

    
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    
    var orangeIcon = L.divIcon({
        className: 'custom-div-icon',
        html: "<div style='background-color: #ea580c; width: 18px; height: 18px; border-radius: 50%; border: 3px solid white; shadow: 0 0 10px rgba(0,0,0,0.3);'></div>",
        iconSize: [18, 18],
        iconAnchor: [9, 9]
    });

    
    L.marker([-23.5874, -46.6576], {icon: orangeIcon}).addTo(map)
        .bindPopup('<b><%= evento.titulo %></b><br><%= evento.local %>')
        .openPopup();
</script>
</body>
</html>