<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrar | EventosPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/48/user-male-circle.png">
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col">

    <nav class="flex justify-between items-center p-6 bg-white shadow-sm">
        <div class="text-2xl font-bold flex items-center gap-2 cursor-pointer" onclick="window.location='/'">
            <span class="p-1 bg-orange-600 rounded-lg text-white text-sm">📅</span> EventosPro
        </div>
        <div class="flex gap-6 items-center text-gray-600 font-medium">
            <a href="/" class="hover:text-orange-600 transition-colors">Eventos</a>
            <button class="bg-orange-600 text-white px-6 py-2 rounded-xl hover:bg-orange-700 transition-all">Entrar</button>
        </div>
    </nav>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-xl border border-gray-100 animate__animated animate__zoomIn">
            
            <div class="flex justify-center mb-6">
                <div class="bg-orange-50 p-4 rounded-2xl">
                    <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                </div>
            </div>

            <h1 class="text-3xl font-black text-center text-gray-900 mb-2">Entrar</h1>
            <p class="text-center text-gray-500 mb-10">Acesse sua conta para gerenciar eventos</p>

            <form action="/login" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">E-mail</label>
                    <input type="email" placeholder="seu@email.com" required
                           class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all text-gray-600">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Senha</label>
                    <input type="password" placeholder="••••••" required
                           class="w-full p-4 rounded-2xl bg-gray-50 border-none focus:ring-2 focus:ring-orange-500 outline-none transition-all text-gray-600">
                </div>

                <button type="submit" id="entrar" class="w-full bg-orange-600 text-white font-bold py-4 rounded-2xl hover:bg-orange-700 active:scale-[0.98] transition-all shadow-lg shadow-orange-100">
                    Entrar
                </button>
            </form>

            <p class="text-center mt-8 text-gray-500">
                Não tem conta? <a href="/registro" class="text-orange-600 font-bold hover:underline">Registre-se</a>
            </p>
        </div>
    </main>
    <script>
        
            document.querySelector('form').addEventListener('submit', function(e) {
            e.preventDefault();
        
            const emailInformado = document.querySelector('input[type="email"]').value;
            const senhaInformada = document.querySelector('input[type="password"]').value;

        
            const usuarioSalvo = JSON.parse(localStorage.getItem('usuario_teste'));

            if (usuarioSalvo && usuarioSalvo.email === emailInformado && usuarioSalvo.senha === senhaInformada) {
            
                perguntarPerfil(); 
            } else {
                Swal.fire('Erro!', 'E-mail ou senha inválidos no LocalStorage.', 'error');
            }
        });

        function perguntarPerfil() {
            Swal.fire({
                title: 'Seja bem-vindo!',
                text: 'Como você deseja utilizar o EventosPro?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Participante',
                cancelButtonText: 'Organizador',
                confirmButtonColor: '#ea580c', 
                cancelButtonColor: '#374151',  
                reverseButtons: true, 
                background: '#fff',
                customClass: {
                    popup: 'rounded-[2rem]',
                    title: 'font-bold text-2xl',
                    confirmButton: 'px-8 py-3 rounded-xl font-bold',
                    cancelButton: 'px-8 py-3 rounded-xl font-bold'
                },
                showClass: {
                    popup: 'animate__animated animate__backInDown'
                },
                hideClass: {
                    popup: 'animate__animated animate__fadeOutUp'
                }
            }).then((result) => {
             if (result.isConfirmed) {
            
                    localStorage.setItem('perfil_escolhido', 'participante');
                    window.location.href = '/dashboard-participante';
                } else if (result.dismiss === Swal.DismissReason.cancel) {
            
                    localStorage.setItem('perfil_escolhido', 'organizador');
                    window.location.href = '/dashboard-organizador';
                }
            });
        }


    </script>
</body>
</html>